{
  "name": "palserver-manager",
  "version": "1.1.0",
  "description": "A simple desktop manager for running and maintaining multiple Palworld dedicated servers — install, configure, and control them all from one app.",
  "main": "./out/main/index.js",
  "author": "KJAyano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PalTools/PalServer-Manager.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir -p never",
    "build:win": "npm run build && electron-builder --win -p never",
    "test:lifecycle": "vitest run tests/server-lifecycle",
    "test:instances": "vitest run tests/instance-management",
    "test:config": "vitest run tests/configuration",
    "test:files": "vitest run tests/file-manager",
    "test:players": "vitest run tests/player-management",
    "test:steamcmd": "vitest run tests/steamcmd-and-templates",
    "test:monitor": "vitest run tests/monitor-and-metrics",
    "test:ipc": "vitest run tests/ipc-contract",
    "test:all": "vitest run --coverage"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@reticlehq/react": "^2.0.0",
    "@reticlehq/vite-plugin": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "electron@39.8.10": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  },
  "build": {
    "appId": "paltools.palservermanager",
    "productName": "PalServer Manager",
    "win": {
      "executableName": "PalServer-Manager",
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "perMachine": false,
      "artifactName": "${name}-${version}-setup.${ext}",
      "shortcutName": "PalServer Manager",
      "uninstallDisplayName": "PalServer Manager",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    }
  }
}
